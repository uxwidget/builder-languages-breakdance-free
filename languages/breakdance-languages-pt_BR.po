msgid "Languages"
msgstr "Idiomas"

msgid "Upgrade to Pro to choose the Breakdance Builder language independently from the WordPress profile."
msgstr "Atualize para o Pro para escolher o idioma do Breakdance Builder independentemente do perfil do WordPress."

msgid "The selected language is not available on your current plan."
msgstr "O idioma selecionado não está disponível no seu plano atual."

msgid "Idioma salvo com sucesso. Agora clique em \"Atualizar\" para recarregar o Breakdance e aplicar a tradução."
msgstr "Idioma salvo com sucesso. Agora clique em \"Atualizar\" para recarregar o Breakdance e aplicar a tradução."

msgid "Builder Language"
msgstr "Idioma do builder"

msgid "Choose the language used in the Breakdance Builder interface, element names, and first-party controls."
msgstr "Escolha o idioma usado na interface do Breakdance Builder, nos nomes dos elementos e nos controles nativos."

msgid "Free plan: translations follow your WordPress profile language when it is included in the free language pack."
msgstr "Plano gratuito: as traduções seguem o idioma do perfil do WordPress quando ele está incluído no pacote de idiomas gratuito."

msgid "Upgrade to Pro"
msgstr "Atualizar para Pro"

msgid "to unlock all 8 languages and choose the builder language here."
msgstr "para desbloquear os 8 idiomas e escolher o idioma do builder aqui."

msgid "Builder language"
msgstr "Idioma do builder"

msgid "Use WordPress profile language"
msgstr "Usar idioma do perfil do WordPress"

msgid "Siga os passos:"
msgstr "Siga os passos:"

msgid "1) Clique em \"Salvar novo idioma\"."
msgstr "1) Clique em \"Salvar novo idioma\"."

msgid "2) Clique em \"Atualizar\"."
msgstr "2) Clique em \"Atualizar\"."

msgid "Salvar novo idioma"
msgstr "Salvar novo idioma"

msgid "Atualizar"
msgstr "Atualizar"

msgid "Permission denied."
msgstr "Permissão negada."

msgid "Upgrade to Pro to choose the builder language here."
msgstr "Atualize para o Pro para escolher o idioma do builder aqui."

msgid "Idioma salvo com sucesso."
msgstr "Idioma salvo com sucesso."

msgid "Salvando idioma..."
msgstr "Salvando idioma..."

msgid "Idioma salvo. Agora clique em \"Atualizar\"."
msgstr "Idioma salvo. Agora clique em \"Atualizar\"."

msgid "Não foi possível salvar o idioma selecionado."
msgstr "Não foi possível salvar o idioma selecionado."

msgid "Breakdance Languages is active, but Breakdance Builder is not active. Activate Breakdance Builder to load the language packs."
msgstr "O Breakdance Languages está ativo, mas o Breakdance Builder não está. Ative o Breakdance Builder para carregar os pacotes de idioma."

