msgid "Status"
msgstr "Статус"

msgid "Development mode"
msgstr "Режим разработки"

msgid "Active"
msgstr "Активный"

msgid "Inactive"
msgstr "Неактивный"

msgid "Build de desenvolvimento: licenciamento Freemius não configurado."
msgstr "Разработанная версия: лицензия Freemius не настроена."

msgid "Ative sua licença para carregar as traduções do Breakdance Builder."
msgstr "Активируйте лицензию, чтобы загрузить переводы Breakdance Builder."

msgid ""
"Sua licença está ativa. Todas as traduções incluídas estão disponíveis."
msgstr "Ваша лицензия активна. Все включенные переводы доступны."

msgid "Conta"
msgstr "Конта"

msgid "Gerenciar licença"
msgstr "Управление лицензией"

msgid "Comprar licença"
msgstr "Купить лицензию"

msgid "Comprar"
msgstr "Купить"

msgid ""
"Ative uma licença válida para usar as traduções do Breakdance Languages."
msgstr ""
"Имеется действующая лицензия для использования в качестве перевода языков "
"брейк-данса."

msgid "The selected language is not available."
msgstr "Выбранный язык недоступен."

msgid "Activate a valid license to use Breakdance Languages."
msgstr "Активируйте действующую лицензию на использование языков брейк-данса."

msgid "Breakdance Languages: activate your license to load translations."
msgstr "Языки брейк-данса: активируйте лицензию, чтобы загрузить переводы."

msgid "Manage license"
msgstr "Управление лицензией"
