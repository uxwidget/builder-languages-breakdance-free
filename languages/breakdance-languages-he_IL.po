msgstr "רישיון"

msgid "Status"
msgstr "סטטוס"

msgid "Development mode"
msgstr "מצב פיתוח"

msgid "Active"
msgstr "פעיל"

msgid "Inactive"
msgstr "לא פעיל"

msgid "Build de desenvolvimento: licenciamento Freemius não configurado."
msgstr "Build desenvolvimento: licenciamento Freemius não configurado."

msgid "Ative sua licença para carregar as traduções do Breakdance Builder."
msgstr "הפעל את הרישיון שלך כדי לטעון את תרגומי Breakdance Builder."

msgid ""
"Sua licença está ativa. Todas as traduções incluídas estão disponíveis."
msgstr "הרישיון שלך פעיל. כל התרגומים הכלולים זמינים."

msgid "Conta"
msgstr "קונטה"

msgid "Gerenciar licença"
msgstr "ניהול רישיון"

msgid "Comprar licença"
msgstr "רכישת רישיון"

msgid "Comprar"
msgstr "לִקְנוֹת"

msgid ""
"Ative uma licença válida para usar as traduções do Breakdance Languages."
msgstr "Ative uma licença válida para usar as traduções לעשות שפות ברייקדאנס."

msgid "The selected language is not available."
msgstr "השפה שנבחרה אינה זמינה."

msgid "Activate a valid license to use Breakdance Languages."
msgstr "הפעל רישיון תקף לשימוש בשפות Breakdance."

msgid "Breakdance Languages: activate your license to load translations."
msgstr "שפות ברייקדאנס: הפעל את הרישיון שלך לטעינת תרגומים."

msgid "Manage license"
msgstr "ניהול רישיון"
