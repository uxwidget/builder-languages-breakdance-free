msgid ""
"Ative uma licença válida para usar as traduções do Breakdance Languages."
msgstr ""
"Ative uma licencja válida para usar as traduções do Breakdance Languages."

msgid "The selected language is not available."
msgstr "Wybrany język jest niedostępny."

msgid "Activate a valid license to use Breakdance Languages."
msgstr "Aktywuj ważną licencję na używanie języków Breakdance."

msgid "Breakdance Languages: activate your license to load translations."
msgstr "Breakdance Languages: aktywuj licencję, aby załadować tłumaczenia."

msgid "Manage license"
msgstr "Zarządzaj licencją"
