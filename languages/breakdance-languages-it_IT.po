msgid ""
"Ative uma licença válida para usar as traduções do Breakdance Languages."
msgstr ""
"Attiva una licenza valida per utilizzare le traduzioni di Breakdance "
"Languages."

msgid "The selected language is not available."
msgstr "La lingua selezionata non è disponibile."

msgid "Activate a valid license to use Breakdance Languages."
msgstr "Attiva una licenza valida per utilizzare Breakdance Languages."

msgid "Breakdance Languages: activate your license to load translations."
msgstr ""
"Breakdance Languages: attiva la tua licenza per caricare le traduzioni."

