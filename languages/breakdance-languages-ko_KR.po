msgstr "영어(미국)"

msgid "Licença"
msgstr "특허"

msgid "Status"
msgstr "상태"

msgid "Development mode"
msgstr "개발 모드"

msgid "Active"
msgstr "활동적인"

msgid "Inactive"
msgstr "비활성"

msgid "Build de desenvolvimento: licenciamento Freemius não configurado."
msgstr "Desenvolvimento 빌드: 라이센스는 Freemius não configurado에서 사용 가능합니다."

msgid "Ative sua licença para carregar as traduções do Breakdance Builder."
msgstr "Breakdance Builder 번역을 로드하려면 라이선스를 활성화하세요."

msgid ""
"Sua licença está ativa. Todas as traduções incluídas estão disponíveis."
msgstr "귀하의 라이센스가 활성화되었습니다. 포함된 모든 번역이 가능합니다."

msgid "Conta"
msgstr "콘타"

msgid "Gerenciar licença"
msgstr "라이선스 관리"

msgid "Comprar licença"
msgstr "라이센스 구매"

msgid "Comprar"
msgstr "구입하다"

msgid ""
"Ative uma licença válida para usar as traduções do Breakdance Languages."
msgstr "Breakdance Languages의 트레이딩과 마찬가지로 유효한 라이센스입니다."

msgid "The selected language is not available."
msgstr "선택한 언어를 사용할 수 없습니다."

msgid "Activate a valid license to use Breakdance Languages."
msgstr "Breakdance 언어를 사용하려면 유효한 라이선스를 활성화하세요."

msgid "Breakdance Languages: activate your license to load translations."
msgstr "브레이크댄스 언어: 번역을 로드하려면 라이센스를 활성화하세요."

msgid "Manage license"
msgstr "라이선스 관리"
